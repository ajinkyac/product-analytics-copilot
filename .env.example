# ─────────────────────────────────────────────
# Product Analytics Copilot — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# ── AI ──────────────────────────────────────
OPENAI_API_KEY=sk-...
# gpt-4o is used for complex queries; gpt-4o-mini for simple ones
OPENAI_MODEL_COMPLEX=gpt-4o
OPENAI_MODEL_SIMPLE=gpt-4o-mini

# Prompt version to use (see packages/api/src/ai/prompts/)
AI_PROMPT_VERSION=v1

# ── Database (PostgreSQL) ───────────────────
DATABASE_URL=postgresql://copilot:copilot@localhost:5432/copilot_dev

# ── DuckDB ──────────────────────────────────
# Path to the DuckDB database file.
# Use :memory: for ephemeral (useful for tests).
DUCKDB_PATH=./data/analytics.duckdb

# Max memory for DuckDB (in GB)
DUCKDB_MEMORY_LIMIT=2GB

# Number of threads for DuckDB query execution
DUCKDB_THREADS=4

# ── API Server ───────────────────────────────
PORT=3001
NODE_ENV=development

# JWT signing secret — generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-openssl-rand

# JWT expiry
JWT_EXPIRES_IN=7d

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173

# ── Ingest ───────────────────────────────────
# Max events per ingest batch
INGEST_MAX_BATCH_SIZE=500

# Max ingest request body size
INGEST_MAX_BODY_KB=512

# ── Web App ───────────────────────────────────
# Public URL of the API server (used by the web app at build time)
VITE_API_URL=http://localhost:3001

# ── S3 (optional — for Parquet cold storage export) ────
# S3_BUCKET=your-analytics-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Redis (optional — for multi-instance query cache) ──
# REDIS_URL=redis://localhost:6379

# ── Rate limiting ────────────────────────────
# Max AI queries per workspace per hour
AI_QUERY_RATE_LIMIT_PER_HOUR=100

# Max ingest requests per write key per minute
INGEST_RATE_LIMIT_PER_MIN=60
