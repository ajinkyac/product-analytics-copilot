{
  "name": "product-analytics-copilot",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:studio": "pnpm --filter api db:studio",
    "seed": "tsx scripts/seed-data.ts"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.4.5"
    }
  },
  "workspaces": [
    "packages/*"
  ]
}
